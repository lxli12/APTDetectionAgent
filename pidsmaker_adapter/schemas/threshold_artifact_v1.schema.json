{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "threshold_artifact_v1",
  "type": "object",
  "required": ["schema_version", "threshold_space_version", "pids", "labels_used", "source_split", "scoring", "score_channel", "options"],
  "properties": {
    "schema_version": {"const": "threshold_artifact_v1"},
    "threshold_space_version": {"const": "pids_tree_validation_v1"},
    "pids": {"enum": ["flash", "kairos", "magic", "nodlink", "orthrus", "rcaid", "threatrace", "velox"]},
    "labels_used": {"const": false},
    "source_split": {"const": "val"},
    "scoring": {"enum": ["direct_node_loss", "max_incident_edge_loss"]},
    "score_channel": {"enum": ["objective_loss", "flash_confidence", "threatrace_ratio"]},
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "method", "resolution", "resolved_value", "expected_benign_exceedance_rate"],
        "properties": {
          "id": {"type": "string"},
          "method": {"enum": ["validation_quantile", "max_val_loss", "mean_val_loss", "flash", "threatrace"]},
          "value": {"type": "number"},
          "resolution": {"type": "string"},
          "resolved_value": {"type": "number"},
          "expected_benign_exceedance_rate": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "allOf": [{
          "if": {"properties": {"method": {"enum": ["validation_quantile", "flash", "threatrace"]}}},
          "then": {"required": ["value"]},
          "else": {"not": {"required": ["value"]}}
        }]
      }
    }
  }
}
