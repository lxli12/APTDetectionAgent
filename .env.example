# Secret-free AutoDL runtime template. Copy to .env on the remote host only.
# Credentials and provider API keys intentionally do not belong in this file.
APT_AGENT_REPOSITORY_ROOT=/root/APTDetectionAgent
APT_AGENT_DATA_ROOT=/root/autodl-tmp

# Agent-owned generated artifacts.
APT_AGENT_EXPERIMENT_ROOT=/root/autodl-tmp/apt-detection-agent/experiments
APT_AGENT_CHECKPOINT_ROOT=/root/autodl-tmp/apt-detection-agent/checkpoints
APT_AGENT_OFFLINE_RUN_TABLE_ROOT=/root/autodl-tmp/apt-detection-agent/offline-run-table

# PIDSMaker-owned generated artifacts. Agent adapters must pass these roots to
# admitted backend invocations; PIDSMaker source remains unchanged.
PIDSMaker_CACHE_ROOT=/root/autodl-tmp/pidsmaker/cache
PIDSMaker_INTERMEDIATE_ROOT=/root/autodl-tmp/pidsmaker/intermediate
PIDSMaker_CHECKPOINT_ROOT=/root/autodl-tmp/pidsmaker/checkpoints
PIDSMaker_OUTPUT_ROOT=/root/autodl-tmp/pidsmaker/outputs

# Dataset, model, package-cache, and database routing.
APT_AGENT_RAW_DATASET_ROOT=/root/autodl-tmp/data/raw_datasets
APT_AGENT_SFT_DATA_ROOT=/root/autodl-tmp/data/sft_data
APT_AGENT_MODEL_ROOT=/root/autodl-tmp/llm-models
HF_HOME=/root/autodl-tmp/huggingface
HUGGINGFACE_HUB_CACHE=/root/autodl-tmp/huggingface/hub
TRANSFORMERS_CACHE=/root/autodl-tmp/huggingface/transformers
PGDATA=/root/autodl-tmp/postgresql/17/main

# Temporary and compilation caches can grow large during remote execution.
TMPDIR=/root/autodl-tmp/tmp
XDG_CACHE_HOME=/root/autodl-tmp/cache
TORCH_HOME=/root/autodl-tmp/cache/torch
