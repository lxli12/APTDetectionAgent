+def _prepare_loaded_datasets(train_data, val_data, test_data, cfg, device):
+    included = [dataset for dataset in (train_data, val_data, test_data) if dataset]
+    if not included:
+        raise ValueError("at least one split is required")
+    full_data = get_full_data(included)
+    max_node = torch.cat([full_data.src, full_data.dst]).max().item() + 1
+    print(f"Max node in {cfg.dataset.name}: {max_node}")
+    graph_reindexer = GraphReindexer(
+        device=device,
+        num_nodes=max_node,
+        fix_buggy_graph_reindexer=cfg.batching.fix_buggy_graph_reindexer,
+    )
+    datasets = run_global_batching(train_data, val_data, test_data, cfg, device)
+    datasets = run_intra_graph_batching(
+        datasets, full_data, device, max_node, cfg, graph_reindexer
+    )
+    datasets = run_reindexing_preprocessing(datasets, graph_reindexer, device, cfg)
+    datasets = run_inter_graph_batching(datasets, cfg)
+    return (*datasets, max_node)
+
+
+def load_train_validation_datasets(cfg, device):
+    """Prepare train/validation without loading or fitting against the test split."""
+    multi_dataset = cfg.batching.multi_dataset_training
+    train_data = load_data_set(cfg, split="train", multi_dataset=multi_dataset)
+    val_data = load_data_set(cfg, split="val", multi_dataset=multi_dataset)
+    train_data, val_data, _test_data, max_node = _prepare_loaded_datasets(
+        train_data, val_data, [], cfg, device
+    )
+    return train_data, val_data, max_node
+
+
+def load_test_dataset(cfg, device):
+    """Prepare only the frozen-model inference split."""
+    test_data = load_data_set(cfg, split="test", multi_dataset=False)
+    _train_data, _val_data, test_data, max_node = _prepare_loaded_datasets(
+        [], [], test_data, cfg, device
+    )
+    return test_data, max_node
